#SeaweedFS

# Key chung cho hệ thống JWT (Nên tạo chuỗi ngẫu nhiên dài)
JWT_SECRET_KEY=OK2Ship_Super_Secret_2026_@#!

# Thông tin đăng nhập MinIO
MINIO_ROOT_USER_HOT=admin_hot
MINIO_ROOT_PASSWORD_HOT=password123_hot
MINIO_ROOT_USER_COLD=admin_cold
MINIO_ROOT_PASSWORD_COLD=password123_cold

#name buckets
BUCKET_NAME_IMAGES=ok2ship-images
BUCKET_NAME_REPORTS=ok2ship-reports

# --- Cấu hình Hot (SSD) ---
MINIO_HOT_API_PORT=9000
MINIO_HOT_CONSOLE_PORT=9001
FOLDER_PATH_SSD=E:/thuyht/ObjectStorage/ssd  # Đường dẫn thực tế

# --- Cấu hình Cold (HDD) ---
MINIO_COLD_API_PORT=9002
MINIO_COLD_CONSOLE_PORT=9003
FOLDER_PATH_HDD=E:/thuyht/ObjectStorage/nas  # Đường dẫn thực tế

#MSSQL Server
#Lưu trữ thư mục vật lý
FOLDER_PATH_SQL=E:/thuyht/Database/sql_data

#config mssql
MSSQL_PASSWORD=YourStrong(!)Password

